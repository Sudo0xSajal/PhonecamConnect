<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0E0C">

    <!-- Camera Preview (full screen background) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:scaleType="fillCenter"/>

    <!-- Dark overlay for UI readability -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#CC0F0E0C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#F0EDE6"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/statusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_offline"
            android:textColor="#F0EDE6"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/badge_offline"/>

    </LinearLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_offline"
        android:textColor="#9A9080"
        android:textSize="13sp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── CONNECT LAYOUT (shown when disconnected) ── -->
    <LinearLayout
        android:id="@+id/layoutConnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus">

        <!-- Main CTA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanQr"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_scan_qr"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1B6FEB"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- Divider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or_manual"
            android:textColor="#5A5248"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <!-- Manual URL input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etManualUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_manual_url"
                android:inputType="textUri"
                android:textColor="#F0EDE6"
                android:textColorHint="#5A5248"
                android:fontFamily="monospace"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManualConnect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_connect"
            app:backgroundTint="#1E1C18"
            app:strokeColor="#2A2721"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>

    <!-- ── STREAMING LAYOUT (shown when connected) ── -->
    <LinearLayout
        android:id="@+id/layoutStreaming"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Resolution picker -->
        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="12dp"
            android:entries="@array/resolutions"/>

        <!-- Camera controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFlipCamera"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/btn_flip"
                app:backgroundTint="#1E1C18"
                app:strokeColor="#2A2721"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTorch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/btn_torch"
                android:alpha="0.5"
                app:backgroundTint="#1E1C18"
                app:strokeColor="#2A2721"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"/>

        </LinearLayout>

        <!-- Disconnect -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDisconnect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_disconnect"
            app:backgroundTint="#FF4757"
            app:strokeColor="#FF4757"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:textColor="#FF4757"/>

    </LinearLayout>

    <!-- Live HUD overlay (top-left of preview) -->
    <LinearLayout
        android:id="@+id/hudOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="72dp"
        android:layout_marginStart="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● REC"
            android:textColor="#FF4757"
            android:textSize="11sp"
            android:background="@drawable/hud_pill"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/hudRes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1080p"
            android:textColor="#F0EDE6"
            android:textSize="11sp"
            android:background="@drawable/hud_pill"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>